// ═══════════════════════════════════════════════════════════
//  BASE CLASS: Employee
// ═══════════════════════════════════════════════════════════
class Employee {
protected:
    std::string name;
    std::string employeeId;   // e.g. "Acc-3", "Cook-5"
    std::string hireDate;
    double      salary;
    std::string status;       // "Active" | "Demoted" | "Promoted"

public:
    // --- Parameterised Constructor ---
    Employee(const std::string& n,
             const std::string& id,
             const std::string& date,
             double sal,
             const std::string& st = "Active")
        : name(n), employeeId(id), hireDate(date), salary(sal), status(st) {
        std::cout << "[Constructor] Employee created: " << name << " (" << employeeId << ")\n";
    }

    // --- Copy Constructor ---
    Employee(const Employee& other)
        : name(other.name), employeeId(other.employeeId),
          hireDate(other.hireDate), salary(other.salary), status(other.status) {
        std::cout << "[Copy Constructor] Copied employee: " << name << "\n";
    }

    // --- Virtual Destructor (essential for polymorphism) ---
    virtual ~Employee() {
        std::cout << "[Destructor] Employee removed: " << name << " (" << employeeId << ")\n";
    }

    // --- Pure Virtual Methods (makes Employee abstract-like) ---
    virtual std::string getRole()     const = 0;
    virtual std::string getRoleCode() const = 0;

    // --- Accessors ---
    std::string getName()       const { return name; }
    std::string getEmployeeId() const { return employeeId; }
    std::string getHireDate()   const { return hireDate; }
    double      getSalary()     const { return salary; }
    std::string getStatus()     const { return status; }

    // --- Mutators ---
    void setName(const std::string& n)   { name = n; }
    void setSalary(double s)             { salary = s; }
    void setStatus(const std::string& s) { status = s; }
    void setEmployeeId(const std::string& id) { employeeId = id; }

    // --- Virtual display ---
    virtual void display() const {
        std::cout << "  ID: "       << employeeId
                  << "  Name: "     << name
                  << "  Role: "     << getRole()
                  << "  Hire: "     << hireDate
                  << "  Salary: "   << salary
                  << "  Status: "   << status << "\n";
    }

    // --- Serialise to CSV line ---
    virtual std::string toCSV() const {
        return name + "," + employeeId + "," + getRole() + "," +
               hireDate + "," + std::to_string(salary) + "," + status;
    }
};

// ═══════════════════════════════════════════════════════════
