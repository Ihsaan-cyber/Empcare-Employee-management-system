            <option value="Accountant">📊 Accountant (Acc)</option>
            <option value="Cook">🍳 Cook (Cook)</option>
            <option value="Assistant">🤝 Assistant (As)</option>
            <option value="Manager">📋 Manager (Mgr)</option>
            <option value="Driver">🚗 Driver (Drv)</option>
          </select>
