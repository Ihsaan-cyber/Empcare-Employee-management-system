    </div>
    <div class="nav-item" onclick="filterRole('Cook')">
      <span class="icon">🍳</span> Cooks
    </div>
    <div class="nav-item" onclick="filterRole('Assistant')">
      <span class="icon">🤝</span> Assistants
    </div>
    <div class="nav-item" onclick="filterRole('Manager')">
      <span class="icon">📋</span> Managers
