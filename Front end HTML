        <div style="overflow-x:auto">
          <table>
            <thead>
              <tr>
                <th>Employee ID</th>
                <th>Name</th>
                <th>Role</th>
                <th>Hire Date</th>
                <th>Salary / mo</th>
                <th>Status</th>
                <th>Actions</th>
