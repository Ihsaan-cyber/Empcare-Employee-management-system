</div>


<!-- ══════════ SCRIPT ══════════ -->
<script>
// ── CONFIG ─────────────────────────────────────────────────
const API = 'http://localhost:8080';

// ── STATE ──────────────────────────────────────────────────
let employees   = [];
let filterStatus = 'all';
let filterRoleStr = '';
let backendOnline = false;

// ── DEMO SEED DATA (used when backend is offline) ──────────
const SEED = [
  { id:'Acc-1',  name:'Aanya Sharma',    role:'Accountant', hireDate:'2023-03-15', salary:42000, status:'Active'   },
  { id:'Acc-2',  name:'Deepa Nair',      role:'Accountant', hireDate:'2022-07-01', salary:45000, status:'Promoted' },
  { id:'As-1',   name:'Arjun Menon',     role:'Assistant',  hireDate:'2024-01-10', salary:22000, status:'Active'   },
  { id:'As-2',   name:'Priya Iyer',      role:'Assistant',  hireDate:'2023-11-20', salary:21000, status:'Active'   },
  { id:'Cook-1', name:'Karthik Pillai',  role:'Cook',       hireDate:'2021-06-05', salary:28000, status:'Active'   },
  { id:'Cook-2', name:'Meera Krishnan',  role:'Cook',       hireDate:'2022-02-28', salary:29500, status:'Promoted' },
  { id:'Drv-1',  name:'Ramesh Babu',     role:'Driver',     hireDate:'2023-08-14', salary:18000, status:'Active'   },
  { id:'Mgr-1',  name:'Sundar Rajan',    role:'Manager',    hireDate:'2020-11-01', salary:65000, status:'Active'   },
];

// ── INIT ───────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', async () => {
  document.getElementById('add-date').valueAsDate = new Date();
  await fetchEmployees();
  checkConnection();
});

async function checkConnection() {
  try {
    const r = await fetch(API + '/employees', { signal: AbortSignal.timeout(1500) });
    if (r.ok) {
      backendOnline = true;
      document.getElementById('conn-status').innerHTML = '🟢 Backend Connected';
    }
  } catch {
    document.getElementById('conn-status').innerHTML = '🟡 Demo Mode (offline)';
  }
}

// ── FETCH ──────────────────────────────────────────────────
async function fetchEmployees() {
  try {
    const r = await fetch(API + '/employees', { signal: AbortSignal.timeout(2000) });
    if (!r.ok) throw new Error();
    employees = await r.json();
    backendOnline = true;
  } catch {
    // Fallback to seed / localStorage
    const stored = localStorage.getItem('bizcore_employees');
    employees = stored ? JSON.parse(stored) : JSON.parse(JSON.stringify(SEED));
  }
  employees.sort((a,b) => a.name.localeCompare(b.name));
  updateStats();
  renderTable();
}

function saveLocal() {
  localStorage.setItem('bizcore_employees', JSON.stringify(employees));
}

// ── STATS ──────────────────────────────────────────────────
function updateStats() {
  const total   = employees.length;
  const active  = employees.filter(e => e.status === 'Active').length;
  const payroll = employees.reduce((s,e) => s + e.salary, 0);
  const avg     = total ? Math.round(payroll / total) : 0;
  document.getElementById('stat-total').textContent   = total;
  document.getElementById('stat-active').textContent  = active;
  document.getElementById('stat-payroll').textContent = '₹' + payroll.toLocaleString('en-IN');
  document.getElementById('stat-avg').textContent     = '₹' + avg.toLocaleString('en-IN');
}

// ── RENDER TABLE ───────────────────────────────────────────
function renderTable() {
  const query = document.getElementById('search-input').value.toLowerCase();

  let list = employees.filter(e => {
    if (filterStatus !== 'all' && e.status !== filterStatus) return false;
    if (filterRoleStr && e.role !== filterRoleStr) return false;
    if (query && !e.name.toLowerCase().includes(query) && !e.id.toLowerCase().includes(query)) return false;
    return true;
  });

  // Always alphabetical by name
  list.sort((a,b) => a.name.localeCompare(b.name));

  const tbody = document.getElementById('emp-tbody');
  if (!list.length) {
    tbody.innerHTML = `<tr><td colspan="7">
      <div class="empty-state">
        <div class="empty-icon">🔍</div>
        <p>No employees found</p>
      </div></td></tr>`;
    return;
  }

  tbody.innerHTML = list.map(e => `
    <tr>
      <td><span class="emp-id">${e.id}</span></td>
      <td><span class="emp-name">${e.name}</span></td>
      <td><span class="role-pill role-${e.role}">${e.role}</span></td>
      <td><span class="emp-date">${formatDate(e.hireDate)}</span></td>
      <td><span class="emp-salary">₹${Number(e.salary).toLocaleString('en-IN')}</span></td>
      <td>${statusBadge(e.status)}</td>
      <td>
        <div class="actions-cell">
          <button class="btn btn-ghost btn-sm" data-tip="Adjust Salary"
            onclick="openSalaryModal('${e.id}','${e.name}',${e.salary})">💰</button>
          <button class="btn btn-ghost btn-sm" data-tip="Change Status"
            onclick="openStatusModal('${e.id}','${e.name}','${e.status}')">🔄</button>
          <button class="btn btn-danger btn-sm" data-tip="Delete"
            onclick="openDeleteModal('${e.id}','${e.name}')">🗑</button>
        </div>
      </td>
    </tr>`).join('');
}

function statusBadge(s) {
  const map = {
    'Active':   'badge-active',
    'Promoted': 'badge-promoted',
    'Demoted':  'badge-demoted',
    'Fired':    'badge-fired',
  };
  const icons = { Active:'●', Promoted:'▲', Demoted:'▼', Fired:'✕' };
  return `<span class="badge ${map[s]||'badge-active'}">${icons[s]||''} ${s}</span>`;
}

function formatDate(d) {
  if (!d) return '—';
  const dt = new Date(d);
  return dt.toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' });
}

// ── FILTERS ────────────────────────────────────────────────
function setFilter(status, btn) {
  filterStatus = status;
  filterRoleStr = '';
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('page-title').textContent = status === 'all' ? 'All Employees' : status + ' Employees';
  renderTable();
}

function filterRole(role) {
  filterRoleStr = role;
  filterStatus  = 'all';
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('page-title').textContent = role + 's';
  renderTable();
}

function setPage(p) {
  filterRoleStr = '';
  filterStatus  = 'all';
  document.getElementById('page-title').textContent = p === 'employees' ? 'All Employees' : 'Payroll Overview';
  document.querySelectorAll('.filter-tab').forEach(t => { t.classList.remove('active'); if(t.textContent.trim()==='All') t.classList.add('active'); });
  renderTable();
}

// ── MODALS ─────────────────────────────────────────────────
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

document.querySelectorAll('.overlay').forEach(o => {
  o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); });
});

function openAddModal() { openModal('modal-add'); }

function openSalaryModal(id, name, salary) {
  document.getElementById('sal-id').value       = id;
  document.getElementById('sal-name').value     = name;
  document.getElementById('sal-current').value  = '₹' + Number(salary).toLocaleString('en-IN');
  document.getElementById('sal-new').value      = salary;
  openModal('modal-salary');
}

function openStatusModal(id, name, status) {
  document.getElementById('st-id').value     = id;
  document.getElementById('st-name').value   = name;
  document.getElementById('st-status').value = status;
  openModal('modal-status');
}

function openDeleteModal(id, name) {
  document.getElementById('del-id').value  = id;
  document.getElementById('del-name').textContent = name + ' [' + id + ']';
  openModal('modal-delete');
}

// ── NEXT LOCAL ID ──────────────────────────────────────────
function nextLocalId(role) {
  const codes = { Accountant:'Acc', Cook:'Cook', Assistant:'As', Manager:'Mgr', Driver:'Drv' };
  const code  = codes[role] || 'Emp';
  const nums  = employees
    .filter(e => e.id.startsWith(code + '-'))
    .map(e => parseInt(e.id.split('-')[1]) || 0);
  const max   = nums.length ? Math.max(...nums) : 0;
  return code + '-' + (max + 1);
}

// ── ADD EMPLOYEE ───────────────────────────────────────────
async function addEmployee() {
  const name   = document.getElementById('add-name').value.trim();
  const role   = document.getElementById('add-role').value;
  const date   = document.getElementById('add-date').value;
  const salary = parseFloat(document.getElementById('add-salary').value);

  if (!name || !role || !date || isNaN(salary)) {
    toast('Please fill in all fields.', true); return;
  }

  if (backendOnline) {
    const fd = new URLSearchParams({ name, role, date, salary });
    const r  = await fetch(API + '/employees', { method:'POST', body:fd });
    const d  = await r.json();
    if (!d.success) { toast('Error: ' + d.message, true); return; }
    await fetchEmployees();
  } else {
    const id = nextLocalId(role);
    employees.push({ id, name, role, hireDate: date, salary, status:'Active' });
    employees.sort((a,b) => a.name.localeCompare(b.name));
    saveLocal();
    updateStats(); renderTable();
  }

  closeModal('modal-add');
  document.getElementById('add-name').value = '';
  document.getElementById('add-role').value = '';
  document.getElementById('add-salary').value = '';
  toast(`✓ ${name} hired as ${role}`);
}

// ── DELETE ─────────────────────────────────────────────────
async function deleteEmployee() {
  const id = document.getElementById('del-id').value;

  if (backendOnline) {
    const fd = new URLSearchParams({ id });
    await fetch(API + '/delete', { method:'POST', body:fd });
    await fetchEmployees();
  } else {
    employees = employees.filter(e => e.id !== id);
    saveLocal();
    updateStats(); renderTable();
  }

  closeModal('modal-delete');
  toast('Employee removed.', false);
}

// ── SALARY ────────────────────────────────────────────────
async function updateSalary() {
  const id     = document.getElementById('sal-id').value;
  const salary = parseFloat(document.getElementById('sal-new').value);
  if (isNaN(salary) || salary < 0) { toast('Enter a valid salary.', true); return; }

  if (backendOnline) {
    const fd = new URLSearchParams({ id, salary });
    await fetch(API + '/salary', { method:'POST', body:fd });
    await fetchEmployees();
  } else {
    const e = employees.find(x => x.id === id);
    if (e) { e.salary = salary; saveLocal(); updateStats(); renderTable(); }
  }

  closeModal('modal-salary');
  toast('✓ Salary updated.');
}

// ── STATUS ────────────────────────────────────────────────
async function updateStatus() {
  const id     = document.getElementById('st-id').value;
  const status = document.getElementById('st-status').value;

  if (backendOnline) {
    const fd = new URLSearchParams({ id, status });
    await fetch(API + '/status', { method:'POST', body:fd });
    await fetchEmployees();
  } else {
    const e = employees.find(x => x.id === id);
    if (e) { e.status = status; saveLocal(); renderTable(); }
  }

  closeModal('modal-status');
  const icons = { Active:'✅', Promoted:'⬆️', Demoted:'⬇️', Fired:'❌' };
  toast(`${icons[status]||''} Status changed to ${status}.`);
}

// ── TOAST ─────────────────────────────────────────────────
function toast(msg, isErr = false) {
  const c = document.getElementById('toast-container');
  const t = document.createElement('div');
  t.className = 'toast' + (isErr ? ' error' : '');
  t.textContent = msg;
  c.appendChild(t);
  setTimeout(() => t.remove(), 3500);
}
</script>
