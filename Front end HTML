  </div>
</div>

<!-- SALARY ADJUST -->
<div class="overlay" id="modal-salary">
  <div class="modal">
    <div class="modal-head">
      <div class="modal-title">Adjust Salary</div>
      <button class="modal-close" onclick="closeModal('modal-salary')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Employee</label>
        <input class="form-input" id="sal-name" readonly style="opacity:0.6" />
