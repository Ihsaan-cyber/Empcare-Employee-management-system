<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BizCore — Employee Management</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
  /* ── RESET & VARIABLES ─────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #0a0b0f;
    --surface:   #111318;
    --surface2:  #181c24;
    --border:    #252a36;
    --accent:    #f0b429;
    --accent2:   #3ecf8e;
    --danger:    #f56565;
    --promote:   #63b3ed;
    --demote:    #fc8181;
    --text:      #e8eaf0;
    --muted:     #6b7280;
    --font-head: 'Syne', sans-serif;
    --font-mono: 'DM Mono', monospace;
    --font-body: 'DM Sans', sans-serif;
    --radius:    10px;
    --shadow:    0 4px 24px rgba(0,0,0,0.45);
  }

  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── BACKGROUND GRID ───────────────────────────────── */
  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background-image:
      linear-gradient(rgba(240,180,41,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(240,180,41,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  /* ── LAYOUT ────────────────────────────────────────── */
  .app { position: relative; z-index: 1; display: flex; min-height: 100vh; }

  /* ── SIDEBAR ───────────────────────────────────────── */
  .sidebar {
    width: 260px; flex-shrink: 0;
    background: var(--surface);
    border-right: 1px solid var(--border);
    display: flex; flex-direction: column;
    padding: 28px 20px;
    position: sticky; top: 0; height: 100vh;
  }
  .logo {
    font-family: var(--font-head);
    font-size: 22px; font-weight: 800;
    color: var(--accent);
    letter-spacing: -0.5px;
    margin-bottom: 6px;
  }
  .logo span { color: var(--text); }
  .logo-sub { font-size: 11px; color: var(--muted); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 36px; }

  .nav-label { font-size: 10px; color: var(--muted); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px; margin-top: 20px; }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px; border-radius: 8px; cursor: pointer;
    font-size: 14px; color: var(--muted);
    transition: all 0.18s; border: 1px solid transparent;
    margin-bottom: 4px;
  }
  .nav-item:hover { background: var(--surface2); color: var(--text); }
  .nav-item.active { background: rgba(240,180,41,0.1); color: var(--accent); border-color: rgba(240,180,41,0.25); }
  .nav-item .icon { width: 18px; text-align: center; font-size: 16px; }

  .sidebar-footer {
    margin-top: auto; padding-top: 20px; border-top: 1px solid var(--border);
    font-size: 12px; color: var(--muted);
  }
  .sidebar-footer strong { color: var(--accent); font-family: var(--font-mono); font-size: 11px; }

  /* ── MAIN AREA ─────────────────────────────────────── */
  .main {
    flex: 1; display: flex; flex-direction: column;
    overflow-x: hidden;
  }

  /* ── TOPBAR ────────────────────────────────────────── */
  .topbar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 16px 32px;
    display: flex; align-items: center; justify-content: space-between;
    position: sticky; top: 0; z-index: 50;
  }
  .topbar-title { font-family: var(--font-head); font-size: 20px; font-weight: 700; }
  .topbar-right { display: flex; align-items: center; gap: 12px; }

  .search-wrap {
    position: relative;
  }
  .search-wrap input {
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 9px 14px 9px 36px;
    color: var(--text); font-size: 13px; width: 220px;
    outline: none; transition: border 0.2s;
    font-family: var(--font-body);
  }
  .search-wrap input:focus { border-color: var(--accent); }
  .search-wrap .search-icon {
    position: absolute; left: 11px; top: 50%; transform: translateY(-50%);
    color: var(--muted); font-size: 14px; pointer-events: none;
  }

  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 16px; border-radius: 8px; font-size: 13px;
    font-weight: 500; cursor: pointer; border: none; transition: all 0.18s;
    font-family: var(--font-body);
  }
  .btn-primary { background: var(--accent); color: #0a0b0f; }
  .btn-primary:hover { background: #ffc84a; transform: translateY(-1px); }
  .btn-ghost { background: transparent; color: var(--muted); border: 1px solid var(--border); }
  .btn-ghost:hover { background: var(--surface2); color: var(--text); }
  .btn-danger { background: rgba(245,101,101,0.12); color: var(--danger); border: 1px solid rgba(245,101,101,0.3); }
  .btn-danger:hover { background: rgba(245,101,101,0.22); }
  .btn-sm { padding: 6px 11px; font-size: 12px; }

  /* ── CONTENT ───────────────────────────────────────── */
  .content { padding: 32px; flex: 1; }

  /* ── STATS ROW ─────────────────────────────────────── */
  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }
  .stat-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 20px;
    transition: border-color 0.2s;
  }
  .stat-card:hover { border-color: rgba(240,180,41,0.3); }
  .stat-label { font-size: 11px; color: var(--muted); letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 8px; }
  .stat-value { font-family: var(--font-head); font-size: 30px; font-weight: 700; color: var(--text); }
  .stat-sub { font-size: 12px; color: var(--muted); margin-top: 4px; }

  /* ── TABLE CARD ────────────────────────────────────── */
  .table-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); overflow: hidden;
  }
  .table-header {
    padding: 18px 24px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
  }
  .table-header-title { font-family: var(--font-head); font-size: 15px; font-weight: 700; }

  .filter-tabs { display: flex; gap: 6px; }
  .filter-tab {
    padding: 5px 12px; border-radius: 20px; font-size: 12px;
    cursor: pointer; border: 1px solid var(--border);
    color: var(--muted); background: transparent;
    transition: all 0.18s; font-family: var(--font-body);
  }
  .filter-tab.active { background: rgba(240,180,41,0.12); color: var(--accent); border-color: rgba(240,180,41,0.3); }
  .filter-tab:hover:not(.active) { background: var(--surface2); color: var(--text); }

  /* ── TABLE ─────────────────────────────────────────── */
  table { width: 100%; border-collapse: collapse; }
  thead tr { border-bottom: 1px solid var(--border); }
  th {
    padding: 12px 20px; font-size: 11px; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--muted); font-weight: 500;
    text-align: left; font-family: var(--font-body);
    white-space: nowrap;
  }
  tbody tr {
    border-bottom: 1px solid rgba(37,42,54,0.6);
    transition: background 0.15s;
  }
  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: var(--surface2); }
  td { padding: 14px 20px; font-size: 13.5px; vertical-align: middle; }

  .emp-name { font-weight: 500; color: var(--text); }
  .emp-id {
    font-family: var(--font-mono); font-size: 12px;
    color: var(--accent); background: rgba(240,180,41,0.1);
    padding: 3px 8px; border-radius: 4px; display: inline-block;
  }
  .emp-date { font-family: var(--font-mono); font-size: 12px; color: var(--muted); }
  .emp-salary { font-family: var(--font-mono); font-size: 13px; color: var(--accent2); }

  .badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px; border-radius: 20px; font-size: 11px;
    font-weight: 500; letter-spacing: 0.5px;
  }
  .badge-active   { background: rgba(62,207,142,0.12); color: var(--accent2); border: 1px solid rgba(62,207,142,0.25); }
  .badge-promoted { background: rgba(99,179,237,0.12); color: var(--promote); border: 1px solid rgba(99,179,237,0.25); }
  .badge-demoted  { background: rgba(252,129,74,0.12); color: #fc814a; border: 1px solid rgba(252,129,74,0.25); }
  .badge-fired    { background: rgba(245,101,101,0.12); color: var(--danger); border: 1px solid rgba(245,101,101,0.25); }

  .role-pill {
    display: inline-block; padding: 3px 10px; border-radius: 4px;
    font-size: 11px; font-weight: 600; letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .role-Accountant { background: rgba(129,140,248,0.12); color: #818cf8; }
  .role-Cook       { background: rgba(251,191,36,0.12);  color: #fbbf24; }
  .role-Assistant  { background: rgba(52,211,153,0.12);  color: #34d399; }
  .role-Manager    { background: rgba(251,113,133,0.12); color: #fb7185; }
  .role-Driver     { background: rgba(125,211,252,0.12); color: #7dd3fc; }

  .actions-cell { display: flex; gap: 6px; flex-wrap: wrap; }

  /* ── EMPTY STATE ───────────────────────────────────── */
  .empty-state {
    text-align: center; padding: 64px 20px;
    color: var(--muted);
  }
  .empty-state .empty-icon { font-size: 48px; margin-bottom: 16px; opacity: 0.5; }
  .empty-state p { font-size: 14px; }

  /* ── MODAL ─────────────────────────────────────────── */
  .overlay {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.2s;
  }
  .overlay.open { opacity: 1; pointer-events: all; }

  .modal {
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 14px; width: 460px; max-width: 95vw;
    box-shadow: var(--shadow);
    transform: translateY(20px); transition: transform 0.25s;
    overflow: hidden;
  }
  .overlay.open .modal { transform: translateY(0); }

  .modal-head {
    padding: 22px 24px 18px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
  }
  .modal-title { font-family: var(--font-head); font-size: 17px; font-weight: 700; }
  .modal-close {
    background: none; border: none; cursor: pointer;
    color: var(--muted); font-size: 20px; line-height: 1;
    transition: color 0.15s; padding: 2px;
  }
  .modal-close:hover { color: var(--text); }

  .modal-body { padding: 24px; }
  .modal-footer { padding: 16px 24px; border-top: 1px solid var(--border); display: flex; gap: 10px; justify-content: flex-end; }

  /* ── FORM ──────────────────────────────────────────── */
  .form-group { margin-bottom: 18px; }
  .form-label { display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px; letter-spacing: 0.5px; }
  .form-input, .form-select {
    width: 100%; background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 14px; color: var(--text);
    font-size: 14px; font-family: var(--font-body); outline: none;
    transition: border-color 0.2s;
  }
  .form-input:focus, .form-select:focus { border-color: var(--accent); }
  .form-select option { background: var(--surface2); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

  /* ── TOAST ─────────────────────────────────────────── */
  #toast-container {
    position: fixed; bottom: 24px; right: 24px; z-index: 999;
    display: flex; flex-direction: column; gap: 10px;
  }
  .toast {
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 10px; padding: 14px 18px;
    display: flex; align-items: center; gap: 10px;
    font-size: 13px; min-width: 260px;
    box-shadow: var(--shadow);
    animation: slideIn 0.25s ease;
    border-left: 3px solid var(--accent2);
  }
  .toast.error { border-left-color: var(--danger); }
  @keyframes slideIn {
    from { opacity: 0; transform: translateX(30px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* ── CONFIRM DIALOG ────────────────────────────────── */
  .confirm-text { font-size: 14px; color: var(--muted); margin-bottom: 6px; }
  .confirm-name { font-family: var(--font-head); font-size: 18px; color: var(--text); }

  /* ── LOADING ───────────────────────────────────────── */
  .loading-row td {
    text-align: center; padding: 48px;
    color: var(--muted); font-size: 13px;
  }
  .spinner {
    display: inline-block; width: 18px; height: 18px;
    border: 2px solid var(--border); border-top-color: var(--accent);
    border-radius: 50%; animation: spin 0.7s linear infinite;
    vertical-align: middle; margin-right: 8px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── TOOLTIP ───────────────────────────────────────── */
  [data-tip] { position: relative; }
  [data-tip]::after {
    content: attr(data-tip);
    position: absolute; bottom: calc(100% + 6px); left: 50%;
    transform: translateX(-50%);
    background: #1e2330; color: var(--text);
    font-size: 11px; white-space: nowrap;
    padding: 4px 9px; border-radius: 5px; pointer-events: none;
    opacity: 0; transition: opacity 0.15s;
    border: 1px solid var(--border);
    z-index: 100;
  }
  [data-tip]:hover::after { opacity: 1; }

  /* ── RESPONSIVE ────────────────────────────────────── */
  @media (max-width: 900px) {
    .sidebar { display: none; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .content { padding: 16px; }
    .stats-row { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }

  /* ── INLINE EDIT ───────────────────────────────────── */
  .salary-inline {
    display: flex; align-items: center; gap: 6px;
  }
  .salary-edit-input {
    background: var(--surface); border: 1px solid var(--accent);
    border-radius: 5px; padding: 4px 8px; color: var(--text);
    font-family: var(--font-mono); font-size: 13px; width: 100px;
    outline: none;
  }
</style>
</head>
<body>

<!-- ══════════ APP ══════════ -->
<div class="app">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="logo">Biz<span>Core</span></div>
    <div class="logo-sub">Management System</div>

    <div class="nav-label">Main</div>
    <div class="nav-item active" onclick="setPage('employees')">
      <span class="icon">👥</span> Employees
    </div>
    <div class="nav-item" onclick="setPage('payroll')">
      <span class="icon">💰</span> Payroll Overview
    </div>

    <div class="nav-label">Roles</div>
    <div class="nav-item" onclick="filterRole('Accountant')">
      <span class="icon">📊</span> Accountants
    </div>
    <div class="nav-item" onclick="filterRole('Cook')">
      <span class="icon">🍳</span> Cooks
    </div>
    <div class="nav-item" onclick="filterRole('Assistant')">
      <span class="icon">🤝</span> Assistants
    </div>
    <div class="nav-item" onclick="filterRole('Manager')">
      <span class="icon">📋</span> Managers
    </div>
    <div class="nav-item" onclick="filterRole('Driver')">
      <span class="icon">🚗</span> Drivers
    </div>

    <div class="sidebar-footer">
      <div style="margin-bottom:4px">Backend</div>
      <strong>C++ HTTP · Port 8080</strong>
      <div style="margin-top:4px" id="conn-status">Connecting…</div>
    </div>
  </aside>

  <!-- MAIN -->
  <div class="main">

    <!-- TOPBAR -->
    <div class="topbar">
      <div class="topbar-title" id="page-title">All Employees</div>
      <div class="topbar-right">
        <div class="search-wrap">
          <span class="search-icon">🔍</span>
          <input type="text" id="search-input" placeholder="Search name or ID…" oninput="renderTable()"/>
        </div>
        <button class="btn btn-primary" onclick="openAddModal()">＋ Hire Employee</button>
      </div>
    </div>

    <!-- CONTENT -->
    <div class="content">

      <!-- STATS -->
      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-label">Total Staff</div>
          <div class="stat-value" id="stat-total">0</div>
          <div class="stat-sub">All employees</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Active</div>
          <div class="stat-value" id="stat-active" style="color:var(--accent2)">0</div>
          <div class="stat-sub">Currently working</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Monthly Payroll</div>
          <div class="stat-value" id="stat-payroll" style="color:var(--accent)">₹0</div>
          <div class="stat-sub">Total salaries</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Avg. Salary</div>
          <div class="stat-value" id="stat-avg" style="font-size:22px">₹0</div>
          <div class="stat-sub">Per employee</div>
        </div>
      </div>

      <!-- TABLE CARD -->
      <div class="table-card">
        <div class="table-header">
          <div class="table-header-title">Employee Directory</div>
          <div class="filter-tabs" id="filter-tabs">
            <button class="filter-tab active" onclick="setFilter('all',this)">All</button>
            <button class="filter-tab" onclick="setFilter('Active',this)">Active</button>
            <button class="filter-tab" onclick="setFilter('Promoted',this)">Promoted</button>
            <button class="filter-tab" onclick="setFilter('Demoted',this)">Demoted</button>
            <button class="filter-tab" onclick="setFilter('Fired',this)">Fired</button>
          </div>
        </div>
        <div style="overflow-x:auto">
          <table>
            <thead>
              <tr>
                <th>Employee ID</th>
                <th>Name</th>
                <th>Role</th>
                <th>Hire Date</th>
                <th>Salary / mo</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="emp-tbody">
              <tr class="loading-row">
                <td colspan="7"><span class="spinner"></span>Loading employees…</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div><!-- /content -->
  </div><!-- /main -->
</div><!-- /app -->

<!-- ══ TOAST CONTAINER ══ -->
<div id="toast-container"></div>

<!-- ══════════ MODALS ══════════ -->

<!-- ADD EMPLOYEE -->
<div class="overlay" id="modal-add">
  <div class="modal">
    <div class="modal-head">
      <div class="modal-title">Hire New Employee</div>
      <button class="modal-close" onclick="closeModal('modal-add')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Full Name *</label>
          <input class="form-input" id="add-name" placeholder="e.g. John Smith" />
        </div>
        <div class="form-group">
          <label class="form-label">Role *</label>
          <select class="form-select" id="add-role">
            <option value="">Select role…</option>
            <option value="Accountant">📊 Accountant (Acc)</option>
            <option value="Cook">🍳 Cook (Cook)</option>
            <option value="Assistant">🤝 Assistant (As)</option>
            <option value="Manager">📋 Manager (Mgr)</option>
            <option value="Driver">🚗 Driver (Drv)</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Hire Date *</label>
          <input class="form-input" id="add-date" type="date" />
        </div>
        <div class="form-group">
          <label class="form-label">Monthly Salary (₹) *</label>
          <input class="form-input" id="add-salary" type="number" placeholder="25000" min="0" />
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-add')">Cancel</button>
      <button class="btn btn-primary" onclick="addEmployee()">✓ Hire Employee</button>
    </div>
  </div>
</div>

<!-- SALARY ADJUST -->
<div class="overlay" id="modal-salary">
  <div class="modal">
    <div class="modal-head">
      <div class="modal-title">Adjust Salary</div>
      <button class="modal-close" onclick="closeModal('modal-salary')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Employee</label>
        <input class="form-input" id="sal-name" readonly style="opacity:0.6" />
      </div>
      <div class="form-group">
        <label class="form-label">Current Salary</label>
        <input class="form-input" id="sal-current" readonly style="opacity:0.6" />
      </div>
      <div class="form-group">
        <label class="form-label">New Monthly Salary (₹) *</label>
        <input class="form-input" id="sal-new" type="number" placeholder="Enter new salary" min="0" />
      </div>
      <input type="hidden" id="sal-id" />
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-salary')">Cancel</button>
      <button class="btn btn-primary" onclick="updateSalary()">✓ Update Salary</button>
    </div>
  </div>
</div>

<!-- STATUS CHANGE -->
<div class="overlay" id="modal-status">
  <div class="modal">
    <div class="modal-head">
      <div class="modal-title">Update Status</div>
      <button class="modal-close" onclick="closeModal('modal-status')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Employee</label>
        <input class="form-input" id="st-name" readonly style="opacity:0.6" />
      </div>
      <div class="form-group">
        <label class="form-label">New Status</label>
        <select class="form-select" id="st-status">
          <option value="Active">✅ Active</option>
          <option value="Promoted">⬆️ Promoted</option>
          <option value="Demoted">⬇️ Demoted</option>
          <option value="Fired">❌ Fired</option>
        </select>
      </div>
      <input type="hidden" id="st-id" />
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-status')">Cancel</button>
      <button class="btn btn-primary" onclick="updateStatus()">✓ Apply</button>
    </div>
  </div>
</div>

<!-- DELETE CONFIRM -->
<div class="overlay" id="modal-delete">
  <div class="modal">
    <div class="modal-head">
      <div class="modal-title" style="color:var(--danger)">⚠ Confirm Deletion</div>
      <button class="modal-close" onclick="closeModal('modal-delete')">✕</button>
    </div>
    <div class="modal-body">
      <p class="confirm-text">You are about to permanently delete:</p>
      <p class="confirm-name" id="del-name">—</p>
      <p style="font-size:13px;color:var(--muted);margin-top:12px">This action cannot be undone. All records for this employee will be removed.</p>
      <input type="hidden" id="del-id" />
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-delete')">Cancel</button>
      <button class="btn btn-danger" onclick="deleteEmployee()">🗑 Delete Permanently</button>
    </div>
  </div>
</div>


<!-- ══════════ SCRIPT ══════════ -->
<script>
// ── CONFIG ─────────────────────────────────────────────────
const API = 'http://localhost:8080';

// ── STATE ──────────────────────────────────────────────────
let employees   = [];
let filterStatus = 'all';
let filterRoleStr = '';
let backendOnline = false;

// ── DEMO SEED DATA (used when backend is offline) ──────────
const SEED = [
  { id:'Acc-1',  name:'Aanya Sharma',    role:'Accountant', hireDate:'2023-03-15', salary:42000, status:'Active'   },
  { id:'Acc-2',  name:'Deepa Nair',      role:'Accountant', hireDate:'2022-07-01', salary:45000, status:'Promoted' },
  { id:'As-1',   name:'Arjun Menon',     role:'Assistant',  hireDate:'2024-01-10', salary:22000, status:'Active'   },
  { id:'As-2',   name:'Priya Iyer',      role:'Assistant',  hireDate:'2023-11-20', salary:21000, status:'Active'   },
  { id:'Cook-1', name:'Karthik Pillai',  role:'Cook',       hireDate:'2021-06-05', salary:28000, status:'Active'   },
  { id:'Cook-2', name:'Meera Krishnan',  role:'Cook',       hireDate:'2022-02-28', salary:29500, status:'Promoted' },
  { id:'Drv-1',  name:'Ramesh Babu',     role:'Driver',     hireDate:'2023-08-14', salary:18000, status:'Active'   },
  { id:'Mgr-1',  name:'Sundar Rajan',    role:'Manager',    hireDate:'2020-11-01', salary:65000, status:'Active'   },
];

// ── INIT ───────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', async () => {
  document.getElementById('add-date').valueAsDate = new Date();
  await fetchEmployees();
  checkConnection();
});

async function checkConnection() {
  try {
    const r = await fetch(API + '/employees', { signal: AbortSignal.timeout(1500) });
    if (r.ok) {
      backendOnline = true;
      document.getElementById('conn-status').innerHTML = '🟢 Backend Connected';
    }
  } catch {
    document.getElementById('conn-status').innerHTML = '🟡 Demo Mode (offline)';
  }
}

// ── FETCH ──────────────────────────────────────────────────
async function fetchEmployees() {
  try {
    const r = await fetch(API + '/employees', { signal: AbortSignal.timeout(2000) });
    if (!r.ok) throw new Error();
    employees = await r.json();
    backendOnline = true;
  } catch {
    // Fallback to seed / localStorage
    const stored = localStorage.getItem('bizcore_employees');
    employees = stored ? JSON.parse(stored) : JSON.parse(JSON.stringify(SEED));
  }
  employees.sort((a,b) => a.name.localeCompare(b.name));
  updateStats();
  renderTable();
}

function saveLocal() {
  localStorage.setItem('bizcore_employees', JSON.stringify(employees));
}

// ── STATS ──────────────────────────────────────────────────
function updateStats() {
  const total   = employees.length;
  const active  = employees.filter(e => e.status === 'Active').length;
  const payroll = employees.reduce((s,e) => s + e.salary, 0);
  const avg     = total ? Math.round(payroll / total) : 0;
  document.getElementById('stat-total').textContent   = total;
  document.getElementById('stat-active').textContent  = active;
  document.getElementById('stat-payroll').textContent = '₹' + payroll.toLocaleString('en-IN');
  document.getElementById('stat-avg').textContent     = '₹' + avg.toLocaleString('en-IN');
}

// ── RENDER TABLE ───────────────────────────────────────────
function renderTable() {
  const query = document.getElementById('search-input').value.toLowerCase();

  let list = employees.filter(e => {
    if (filterStatus !== 'all' && e.status !== filterStatus) return false;
    if (filterRoleStr && e.role !== filterRoleStr) return false;
    if (query && !e.name.toLowerCase().includes(query) && !e.id.toLowerCase().includes(query)) return false;
    return true;
  });

  // Always alphabetical by name
  list.sort((a,b) => a.name.localeCompare(b.name));

  const tbody = document.getElementById('emp-tbody');
  if (!list.length) {
    tbody.innerHTML = `<tr><td colspan="7">
      <div class="empty-state">
        <div class="empty-icon">🔍</div>
        <p>No employees found</p>
      </div></td></tr>`;
    return;
  }

  tbody.innerHTML = list.map(e => `
    <tr>
      <td><span class="emp-id">${e.id}</span></td>
      <td><span class="emp-name">${e.name}</span></td>
      <td><span class="role-pill role-${e.role}">${e.role}</span></td>
      <td><span class="emp-date">${formatDate(e.hireDate)}</span></td>
      <td><span class="emp-salary">₹${Number(e.salary).toLocaleString('en-IN')}</span></td>
      <td>${statusBadge(e.status)}</td>
      <td>
        <div class="actions-cell">
          <button class="btn btn-ghost btn-sm" data-tip="Adjust Salary"
            onclick="openSalaryModal('${e.id}','${e.name}',${e.salary})">💰</button>
          <button class="btn btn-ghost btn-sm" data-tip="Change Status"
            onclick="openStatusModal('${e.id}','${e.name}','${e.status}')">🔄</button>
          <button class="btn btn-danger btn-sm" data-tip="Delete"
            onclick="openDeleteModal('${e.id}','${e.name}')">🗑</button>
        </div>
      </td>
    </tr>`).join('');
}

function statusBadge(s) {
  const map = {
    'Active':   'badge-active',
    'Promoted': 'badge-promoted',
    'Demoted':  'badge-demoted',
    'Fired':    'badge-fired',
  };
  const icons = { Active:'●', Promoted:'▲', Demoted:'▼', Fired:'✕' };
  return `<span class="badge ${map[s]||'badge-active'}">${icons[s]||''} ${s}</span>`;
}

function formatDate(d) {
  if (!d) return '—';
  const dt = new Date(d);
  return dt.toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' });
}

// ── FILTERS ────────────────────────────────────────────────
function setFilter(status, btn) {
  filterStatus = status;
  filterRoleStr = '';
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('page-title').textContent = status === 'all' ? 'All Employees' : status + ' Employees';
  renderTable();
}

function filterRole(role) {
  filterRoleStr = role;
  filterStatus  = 'all';
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('page-title').textContent = role + 's';
  renderTable();
}

function setPage(p) {
  filterRoleStr = '';
  filterStatus  = 'all';
  document.getElementById('page-title').textContent = p === 'employees' ? 'All Employees' : 'Payroll Overview';
  document.querySelectorAll('.filter-tab').forEach(t => { t.classList.remove('active'); if(t.textContent.trim()==='All') t.classList.add('active'); });
  renderTable();
}

// ── MODALS ─────────────────────────────────────────────────
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

document.querySelectorAll('.overlay').forEach(o => {
  o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); });
});

function openAddModal() { openModal('modal-add'); }

function openSalaryModal(id, name, salary) {
  document.getElementById('sal-id').value       = id;
  document.getElementById('sal-name').value     = name;
  document.getElementById('sal-current').value  = '₹' + Number(salary).toLocaleString('en-IN');
  document.getElementById('sal-new').value      = salary;
  openModal('modal-salary');
}

function openStatusModal(id, name, status) {
  document.getElementById('st-id').value     = id;
  document.getElementById('st-name').value   = name;
  document.getElementById('st-status').value = status;
  openModal('modal-status');
}

function openDeleteModal(id, name) {
  document.getElementById('del-id').value  = id;
  document.getElementById('del-name').textContent = name + ' [' + id + ']';
  openModal('modal-delete');
}

// ── NEXT LOCAL ID ──────────────────────────────────────────
function nextLocalId(role) {
  const codes = { Accountant:'Acc', Cook:'Cook', Assistant:'As', Manager:'Mgr', Driver:'Drv' };
  const code  = codes[role] || 'Emp';
  const nums  = employees
    .filter(e => e.id.startsWith(code + '-'))
    .map(e => parseInt(e.id.split('-')[1]) || 0);
  const max   = nums.length ? Math.max(...nums) : 0;
  return code + '-' + (max + 1);
}

// ── ADD EMPLOYEE ───────────────────────────────────────────
async function addEmployee() {
  const name   = document.getElementById('add-name').value.trim();
  const role   = document.getElementById('add-role').value;
  const date   = document.getElementById('add-date').value;
  const salary = parseFloat(document.getElementById('add-salary').value);

  if (!name || !role || !date || isNaN(salary)) {
    toast('Please fill in all fields.', true); return;
  }

  if (backendOnline) {
    const fd = new URLSearchParams({ name, role, date, salary });
    const r  = await fetch(API + '/employees', { method:'POST', body:fd });
    const d  = await r.json();
    if (!d.success) { toast('Error: ' + d.message, true); return; }
    await fetchEmployees();
  } else {
    const id = nextLocalId(role);
    employees.push({ id, name, role, hireDate: date, salary, status:'Active' });
    employees.sort((a,b) => a.name.localeCompare(b.name));
    saveLocal();
    updateStats(); renderTable();
  }

  closeModal('modal-add');
  document.getElementById('add-name').value = '';
  document.getElementById('add-role').value = '';
  document.getElementById('add-salary').value = '';
  toast(`✓ ${name} hired as ${role}`);
}

// ── DELETE ─────────────────────────────────────────────────
async function deleteEmployee() {
  const id = document.getElementById('del-id').value;

  if (backendOnline) {
    const fd = new URLSearchParams({ id });
    await fetch(API + '/delete', { method:'POST', body:fd });
    await fetchEmployees();
  } else {
    employees = employees.filter(e => e.id !== id);
    saveLocal();
    updateStats(); renderTable();
  }

  closeModal('modal-delete');
  toast('Employee removed.', false);
}

// ── SALARY ────────────────────────────────────────────────
async function updateSalary() {
  const id     = document.getElementById('sal-id').value;
  const salary = parseFloat(document.getElementById('sal-new').value);
  if (isNaN(salary) || salary < 0) { toast('Enter a valid salary.', true); return; }

  if (backendOnline) {
    const fd = new URLSearchParams({ id, salary });
    await fetch(API + '/salary', { method:'POST', body:fd });
    await fetchEmployees();
  } else {
    const e = employees.find(x => x.id === id);
    if (e) { e.salary = salary; saveLocal(); updateStats(); renderTable(); }
  }

  closeModal('modal-salary');
  toast('✓ Salary updated.');
}

// ── STATUS ────────────────────────────────────────────────
async function updateStatus() {
  const id     = document.getElementById('st-id').value;
  const status = document.getElementById('st-status').value;

  if (backendOnline) {
    const fd = new URLSearchParams({ id, status });
    await fetch(API + '/status', { method:'POST', body:fd });
    await fetchEmployees();
  } else {
    const e = employees.find(x => x.id === id);
    if (e) { e.status = status; saveLocal(); renderTable(); }
  }

  closeModal('modal-status');
  const icons = { Active:'✅', Promoted:'⬆️', Demoted:'⬇️', Fired:'❌' };
  toast(`${icons[status]||''} Status changed to ${status}.`);
}

// ── TOAST ─────────────────────────────────────────────────
function toast(msg, isErr = false) {
  const c = document.getElementById('toast-container');
  const t = document.createElement('div');
  t.className = 'toast' + (isErr ? ' error' : '');
  t.textContent = msg;
  c.appendChild(t);
  setTimeout(() => t.remove(), 3500);
}
</script>
</body>
